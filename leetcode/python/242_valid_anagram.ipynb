   "source": [
    "Given two strings s and t, return true if t is an anagram of s, and false otherwise."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 1,
   "id": "e4ad10be",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "True\n"
     ]
    }
   ],
   "source": [
    "from collections import Counter\n",
    "\n",
    "s = input()\n",
    "t = input()\n",
    "\n",
    "s1 = Counter(s)\n",
    "s2 = Counter(t)\n",
    "\n",
    "if s1 == s2:\n",
    "    print(True)\n",
    "else:\n",
    "    print(False)    \n"
   ]
  },
